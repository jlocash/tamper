{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "tamper/app/mcp/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "project": ".",
    "editable": ["."]
  },
  "deployment": {
    "transport": "http",
    "host": "0.0.0.0",
    "port": 8000,
    "log_level": "INFO",
    "env": {
      "TAMPER_HOME": "${HOME}/.tamper"
    }
  }
}
