@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix tamper: <https://example.org/tamper/core#> .

<https://example.org/tamper/core> a owl:Ontology ;
    rdfs:label "Tamper Ontology"@en ;
    rdfs:comment "An ontology for representing media assets, their structure, and provenance for forensic analysis."@en ;
    owl:imports <http://www.w3.org/ns/prov#> ;
    owl:versionIRI <https://example.org/tamper/core/0.1.0> ;
    owl:versionInfo "0.1.0" .

#################################################################
# Classes
#################################################################

tamper:MediaAsset a owl:Class ;
    rdfs:label "Media Asset"@en ;
    rdfs:comment "A digital media file such as an image, audio, or video."@en ;
    rdfs:subClassOf prov:Entity .

tamper:ImageAsset a owl:Class ;
    rdfs:label "Image Asset"@en ;
    rdfs:comment "A digital image file."@en ;
    rdfs:subClassOf tamper:MediaAsset .

tamper:StreamContainer a owl:Class ;
    rdfs:label "Stream Container"@en ;
    rdfs:comment "A media asset that contains one or more streams (e.g., video or audio files)."@en ;
    rdfs:subClassOf tamper:MediaAsset .

tamper:AudioAsset a owl:Class ;
    rdfs:label "Audio Asset"@en ;
    rdfs:comment "A digital audio file containing one or more audio streams."@en ;
    rdfs:subClassOf tamper:StreamContainer .

tamper:VideoAsset a owl:Class ;
    rdfs:label "Video Asset"@en ;
    rdfs:comment "A digital video file containing video and potentially audio streams."@en ;
    rdfs:subClassOf tamper:StreamContainer .

tamper:Stream a owl:Class ;
    rdfs:label "Stream"@en ;
    rdfs:comment "A component stream within a media container."@en .

tamper:VideoStream a owl:Class ;
    rdfs:label "Video Stream"@en ;
    rdfs:comment "A stream containing video frame data."@en ;
    rdfs:subClassOf tamper:Stream .

tamper:AudioStream a owl:Class ;
    rdfs:label "Audio Stream"@en ;
    rdfs:comment "A stream containing audio sample data."@en ;
    rdfs:subClassOf tamper:Stream .

tamper:SubtitleStream a owl:Class ;
    rdfs:label "Subtitle Stream"@en ;
    rdfs:comment "A stream containing subtitle or caption data."@en ;
    rdfs:subClassOf tamper:Stream .

tamper:Operation a owl:Class ;
    rdfs:label "Operation"@en ;
    rdfs:comment "An operation is a process that results in the creation of a new media asset."@en ;
    rdfs:subClassOf prov:Activity .

tamper:ImageOperation a owl:Class ;
    rdfs:label "Image Operation"@en ;
    rdfs:comment "An operation that results in the creation of an image."@en ;
    rdfs:subClassOf tamper:Operation .

tamper:CompressJPEG a owl:Class ;
    rdfs:label "Compress JPEG"@en ;
    rdfs:comment "Applies JPEG compression to an image."@en ;
    rdfs:subClassOf tamper:ImageOperation .

tamper:CompressWebP a owl:Class ;
    rdfs:label "Compress WebP"@en ;
    rdfs:comment "Applies WebP compression to an image."@en ;
    rdfs:subClassOf tamper:ImageOperation .

tamper:AddGaussianNoise a owl:Class ;
    rdfs:label "Add Gaussian Noise"@en ;
    rdfs:comment "Adds gaussian noise to an image."@en ;
    rdfs:subClassOf tamper:ImageOperation .

tamper:Resize a owl:Class ;
    rdfs:label "Resize"@en ;
    rdfs:comment "Resamples an image to a target width and height using a specified interpolation method."@en ;
    rdfs:subClassOf tamper:ImageOperation .

tamper:MedianFilter a owl:Class ;
    rdfs:label "Median Filter"@en ;
    rdfs:comment "Applies a median filter over a square neighbourhood, commonly used to suppress noise residuals."@en ;
    rdfs:subClassOf tamper:ImageOperation .

tamper:GaussianBlur a owl:Class ;
    rdfs:label "Gaussian Blur"@en ;
    rdfs:comment "Convolves an image with a Gaussian kernel of a given size and standard deviation."@en ;
    rdfs:subClassOf tamper:ImageOperation .

tamper:CropImage a owl:Class ;
    rdfs:label "Crop Image"@en ;
    rdfs:comment "Extracts a rectangular region from an image, given a top-left origin and a width and height."@en ;
    rdfs:subClassOf tamper:ImageOperation .

tamper:VideoOperation a owl:Class ;
    rdfs:label "Video Operation"@en ;
    rdfs:comment "An operation that results in the creation of a video."@en ;
    rdfs:subClassOf tamper:Operation .

tamper:TranscodeVideo a owl:Class ;
    rdfs:label "Transcode Video"@en ;
    rdfs:comment "Re-encodes a video's video stream using a specified encoder and quality (CRF). The audio stream is copied without re-encoding."@en ;
    rdfs:subClassOf tamper:VideoOperation .

tamper:AudioOperation a owl:Class ;
    rdfs:label "Audio Operation"@en ;
    rdfs:comment "An operation that results in the creation of an audio asset."@en ;
    rdfs:subClassOf tamper:Operation .

tamper:TranscodeAudio a owl:Class ;
    rdfs:label "Transcode Audio"@en ;
    rdfs:comment "Re-encodes an audio stream using a specified encoder and target bit rate."@en ;
    rdfs:subClassOf tamper:AudioOperation .

tamper:ResampleAudio a owl:Class ;
    rdfs:label "Resample Audio"@en ;
    rdfs:comment "Resamples an audio stream to a target sample rate."@en ;
    rdfs:subClassOf tamper:AudioOperation .

#################################################################
# Object Properties
#################################################################

tamper:hasStream a owl:ObjectProperty ;
    rdfs:label "has stream"@en ;
    rdfs:comment "Relates a stream container to its constituent streams."@en ;
    rdfs:domain tamper:StreamContainer ;
    rdfs:range tamper:Stream .

#################################################################
# Datatype Properties - Common
#################################################################

tamper:mediaType a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "media type"@en ;
    rdfs:comment "The MIME type of the media asset (e.g., 'image/jpeg', 'video/mp4')."@en ;
    rdfs:domain tamper:MediaAsset ;
    rdfs:range xsd:string .

tamper:fileSize a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "file size"@en ;
    rdfs:comment "The size of the media file in bytes."@en ;
    rdfs:domain tamper:MediaAsset ;
    rdfs:range xsd:long .

tamper:filePath a owl:DatatypeProperty ;
    rdfs:label "file path"@en ;
    rdfs:comment "The relative path to the media file."@en ;
    rdfs:domain tamper:MediaAsset ;
    rdfs:range xsd:string .

tamper:checksum a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "checksum"@en ;
    rdfs:comment "The checksum of the media file, formatted as \"algorithm:checksum\" (e.g \"sha256:5e70b96ad27dc8581424be7069ee9de8da9388b716e6fe213d88385f19baf80a\")."@en ;
    rdfs:domain tamper:MediaAsset ;
    rdfs:range xsd:string .

#################################################################
# Datatype Properties - Container-specific
#################################################################

tamper:containerFormat a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "container format"@en ;
    rdfs:comment "The container format name (e.g., 'MPEG-4', 'Matroska', 'FLAC')."@en ;
    rdfs:domain tamper:StreamContainer ;
    rdfs:range xsd:string .

tamper:duration a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "duration"@en ;
    rdfs:comment "The temporal duration of the media."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:StreamContainer
            tamper:Stream
        )
    ] ;
    rdfs:range xsd:duration .

#################################################################
# Datatype Properties - Stream-specific
#################################################################

tamper:streamIndex a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "stream index"@en ;
    rdfs:comment "The zero-based index of the stream within its container."@en ;
    rdfs:domain tamper:Stream ;
    rdfs:range xsd:integer .

tamper:codec a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "codec"@en ;
    rdfs:comment "The codec used to encode the stream (e.g., 'h264', 'aac', 'mp3')."@en ;
    rdfs:domain tamper:Stream ;
    rdfs:range xsd:string .

tamper:bitRate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "bit rate"@en ;
    rdfs:comment "The bit rate of the stream in bits per second."@en ;
    rdfs:domain tamper:Stream ;
    rdfs:range xsd:integer .

tamper:language a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "language"@en ;
    rdfs:comment "The ISO 639 language code for the stream content."@en ;
    rdfs:domain tamper:Stream ;
    rdfs:range xsd:string .

#################################################################
# Datatype Properties - Visual (Images and Video Streams)
#################################################################

tamper:width a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "width"@en ;
    rdfs:comment "The width in pixels."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:ImageAsset
            tamper:VideoStream
        )
    ] ;
    rdfs:range xsd:integer .

tamper:height a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "height"@en ;
    rdfs:comment "The height in pixels."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:ImageAsset
            tamper:VideoStream
        )
    ] ;
    rdfs:range xsd:integer .

tamper:colorSpace a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "color space"@en ;
    rdfs:comment "The color space of the visual data (e.g., 'sRGB', 'bt709', 'bt2020')."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:ImageAsset
            tamper:VideoStream
        )
    ] ;
    rdfs:range xsd:string .

tamper:bitDepth a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "bit depth"@en ;
    rdfs:comment "The number of bits per pixel channel."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:ImageAsset
            tamper:VideoStream
        )
    ] ;
    rdfs:range xsd:integer .

tamper:pixelFormat a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "pixel format"@en ;
    rdfs:comment "The pixel format (e.g., 'yuv420p', 'rgb24')."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:ImageAsset
            tamper:VideoStream
        )
    ] ;
    rdfs:range xsd:string .

#################################################################
# Datatype Properties - Video Stream specific
#################################################################

tamper:frameRate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "frame rate"@en ;
    rdfs:comment "The frame rate in frames per second."@en ;
    rdfs:domain tamper:VideoStream ;
    rdfs:range xsd:double .


#################################################################
# Datatype Properties - Audio Stream specific
#################################################################

tamper:sampleRate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "sample rate"@en ;
    rdfs:comment "The audio sample rate in Hertz."@en ;
    rdfs:domain tamper:AudioStream ;
    rdfs:range xsd:integer .

tamper:channels a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "channels"@en ;
    rdfs:comment "The number of audio channels."@en ;
    rdfs:domain tamper:AudioStream ;
    rdfs:range xsd:integer .

tamper:bitsPerSample a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "bits per sample"@en ;
    rdfs:comment "The number of bits per audio sample."@en ;
    rdfs:domain tamper:AudioStream ;
    rdfs:range xsd:integer .

#################################################################
# Datatype Properties - Operation specific
#################################################################

tamper:qualityFactor a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "quality factor"@en ;
    rdfs:comment "JPEG compression quality factor (0 - 100)" ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:CompressJPEG
            tamper:CompressWebP
        )
    ] ;
    rdfs:range xsd:integer .

tamper:gaussianMean a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "gaussian mean"@en ;
    rdfs:domain tamper:AddGaussianNoise ;
    rdfs:range xsd:double .

tamper:gaussianStd a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "gaussian std"@en ;
    rdfs:domain tamper:AddGaussianNoise ;
    rdfs:range xsd:double .

tamper:gaussianSeed a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "gaussian seed"@en ;
    rdfs:comment "The seed for the random number generator used to draw the noise, recorded so the operation is exactly reproducible."@en ;
    rdfs:domain tamper:AddGaussianNoise ;
    rdfs:range xsd:integer .

tamper:targetWidth a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "target width"@en ;
    rdfs:comment "The target width in pixels for a resize operation."@en ;
    rdfs:domain tamper:Resize ;
    rdfs:range xsd:integer .

tamper:targetHeight a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "target height"@en ;
    rdfs:comment "The target height in pixels for a resize operation."@en ;
    rdfs:domain tamper:Resize ;
    rdfs:range xsd:integer .

tamper:interpolation a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "interpolation"@en ;
    rdfs:comment "The interpolation method used when resampling (e.g., 'nearest', 'linear', 'cubic', 'area', 'lanczos4')."@en ;
    rdfs:domain tamper:Resize ;
    rdfs:range xsd:string .

tamper:kernelSize a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "kernel size"@en ;
    rdfs:comment "The side length, in pixels, of the square convolution kernel. Must be a positive odd integer."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            tamper:MedianFilter
            tamper:GaussianBlur
        )
    ] ;
    rdfs:range xsd:integer .

tamper:blurSigma a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "blur sigma"@en ;
    rdfs:comment "The Gaussian kernel standard deviation. A value of 0 lets the implementation derive it from the kernel size."@en ;
    rdfs:domain tamper:GaussianBlur ;
    rdfs:range xsd:double .

tamper:cropX a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "crop x"@en ;
    rdfs:comment "The x coordinate, in pixels, of the top-left corner of the crop region."@en ;
    rdfs:domain tamper:CropImage ;
    rdfs:range xsd:integer .

tamper:cropY a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "crop y"@en ;
    rdfs:comment "The y coordinate, in pixels, of the top-left corner of the crop region."@en ;
    rdfs:domain tamper:CropImage ;
    rdfs:range xsd:integer .

tamper:cropWidth a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "crop width"@en ;
    rdfs:comment "The width in pixels of the crop region."@en ;
    rdfs:domain tamper:CropImage ;
    rdfs:range xsd:integer .

tamper:cropHeight a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "crop height"@en ;
    rdfs:comment "The height in pixels of the crop region."@en ;
    rdfs:domain tamper:CropImage ;
    rdfs:range xsd:integer .

tamper:videoEncoder a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "video encoder"@en ;
    rdfs:comment "The name of the video encoder used for transcoding (e.g., 'libx264', 'libx265', 'libvpx-vp9')."@en ;
    rdfs:domain tamper:TranscodeVideo ;
    rdfs:range xsd:string .

tamper:crf a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "CRF"@en ;
    rdfs:comment "Constant Rate Factor — a perceptual-quality target for the encoder. Lower values mean higher quality and larger file size; 0 is lossless on x264."@en ;
    rdfs:domain tamper:TranscodeVideo ;
    rdfs:range xsd:integer .

tamper:audioEncoder a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "audio encoder"@en ;
    rdfs:comment "The name of the audio encoder used for transcoding (e.g., 'libmp3lame', 'aac', 'libopus')."@en ;
    rdfs:domain tamper:TranscodeAudio ;
    rdfs:range xsd:string .

tamper:targetBitRate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "target bit rate"@en ;
    rdfs:comment "The target bit rate in bits per second for an audio transcode operation."@en ;
    rdfs:domain tamper:TranscodeAudio ;
    rdfs:range xsd:integer .

tamper:targetSampleRate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "target sample rate"@en ;
    rdfs:comment "The target sample rate in Hertz for an audio resample operation."@en ;
    rdfs:domain tamper:ResampleAudio ;
    rdfs:range xsd:integer .


[] a owl:AllDisjointClasses ;
    owl:members (
        tamper:ImageAsset
        tamper:AudioAsset
        tamper:VideoAsset
    ) .

[] a owl:AllDisjointClasses ;
    owl:members (
        tamper:VideoStream
        tamper:AudioStream
        tamper:SubtitleStream
    ) .
